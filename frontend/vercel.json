{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 120,
      "includeFiles": "api/lib/**"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...path]?...path=$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
