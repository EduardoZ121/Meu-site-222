{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 9 * * 6"
    }
  ],
  "framework": "create-react-app",
  "functions": {
    "frontend/api/**/*.js": {
      "maxDuration": 120,
      "includeFiles": "frontend/api/lib/**"
    },
    "api/**/*.js": {
      "maxDuration": 120,
      "includeFiles": "frontend/api/lib/**"
    }
  },
  "installCommand": "ln -sfn frontend/api api 2>/dev/null; yarn install --frozen-lockfile || yarn install && cd frontend && yarn install --frozen-lockfile || yarn install",
  "buildCommand": "cd frontend && REACT_APP_BUILD_ID=upload-studio-v4 yarn build",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ],
      "has": [
        { "type": "header", "key": "accept", "value": "text/html" }
      ]
    }
  ],
  "outputDirectory": "frontend/build",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...path]?...path=$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
