{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 9 * * 6"
    }
  ],
  "framework": "create-react-app",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 120,
      "includeFiles": "frontend/api/lib/**"
    }
  },
  "installCommand": "ln -sfn frontend/api api && yarn install --frozen-lockfile && cd frontend && yarn install --frozen-lockfile",
  "buildCommand": "cd frontend && yarn build",
  "outputDirectory": "frontend/build",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...path]?...path=$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
