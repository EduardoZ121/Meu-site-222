{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "buildCommand": "REACT_APP_DISABLE_VERCEL_BLOB=0 yarn build",
  "outputDirectory": "build",
  "installCommand": "yarn install --ignore-engines || yarn install",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 800,
      "memory": 3009,
      "includeFiles": "{api/lib/**,node_modules/sharp/**,node_modules/@img/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 9 * * 6"
    },
    {
      "path": "/api/cron/finalize-pending",
      "schedule": "*/3 * * * *"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...path]?...path=$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}
